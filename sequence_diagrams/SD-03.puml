@startuml SD-03
skinparam backgroundColor #FAFAFA
skinparam roundcorner 10
skinparam shadowing false
skinparam sequenceArrowThickness 1.5
skinparam sequenceLifeLineBorderColor #888888
skinparam sequenceParticipantBorderColor #444444
skinparam sequenceParticipantFontSize 12
skinparam sequenceMessageFontSize 11

title SD-03: Pencarian Mushola (Fasilitas Ibadah)

actor "Pengunjung\n(Browser)" as User #4A90D9
participant "Laravel\n(ChatbotController)" as Laravel #2E8B57
participant "ChatbotService\n(Laravel)" as Service #50C878
participant "Flask\n(app.py)" as Flask #E67E22
participant "ChatbotEngine\n(engine.py)" as Engine #8E44AD
participant "Search\n(search.py)" as Search #C0392B

== 1. User Tanya Lokasi Mushola ==
User -> Laravel : POST /chat\n{message: "dimana mushola?"}
activate Laravel
Laravel -> Service : predict("dimana mushola?")
activate Service
Service -> Flask : POST /predict\n{message: "dimana mushola?"}
activate Flask

== 2. Deteksi Tema Mushola ==
Flask -> Engine : process("dimana mushola?")
activate Engine
Engine -> Search : collaborative_search("mushola")
activate Search
note right of Search
  Deteksi THEME "mushola"
  Keyword: mushola, ibadah, shalat
  Kumpulkan semua mushola
  → Return opsi daftar mushola
end note
Search --> Engine : [{id:"15", name:"Mushola Gedung A"},\n{id:"16", name:"Mushola Gedung B"}],\nscore=0.95, is_option=true
deactivate Search
Engine --> Flask : (options, score=0.95, is_option=true)
deactivate Engine
Flask --> Service : {options: [Mushola A, Mushola B],\nresponse: "Silakan pilih lokasi terdekat Anda:"}
deactivate Flask
Service --> Laravel : {options: [...], intent: "cari_ruangan"}
deactivate Service
Laravel --> User : JSON {options, message}
deactivate Laravel

note over User
  Browser tampilkan tombol:
  [Mushola Gedung A] [Mushola Gedung B]
end note

== 3. User Pilih Mushola ==
User -> Laravel : POST /chat\n{message: "15"}
activate Laravel
Laravel -> Service : predict("15")
activate Service
Service -> Flask : POST /predict\n{message: "15"}
activate Flask

== 4. Cari Berdasarkan ID Ruangan ==
Flask -> Engine : process("15")
activate Engine
Engine -> Search : collaborative_search("15")
activate Search
note right of Search
  Deteksi pesan = angka
  Cek apakah ID ada di database
  → Return langsung room_id=15
end note
Search --> Engine : room_id=15, score=1.0, is_option=false
deactivate Search
Engine --> Flask : (room_id=15, score=1.0)
deactivate Engine
Flask --> Service : {best_room_id: 15, response: "Mushola terletak di..."}
deactivate Flask
Service --> Laravel : {rooms: [Mushola Gedung A], intent}
deactivate Service
Laravel --> User : JSON {message, rooms, intent}
deactivate Laravel

note over User
  Browser tampilkan:
  "Card Informasi Mushola Gedung A"
  + Foto + Navigasi
end note

@enduml
