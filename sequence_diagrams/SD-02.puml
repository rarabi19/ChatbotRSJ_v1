@startuml SD-02
skinparam backgroundColor #FAFAFA
skinparam roundcorner 10
skinparam shadowing false
skinparam sequenceArrowThickness 1.5
skinparam sequenceLifeLineBorderColor #888888
skinparam sequenceParticipantBorderColor #444444
skinparam sequenceParticipantFontSize 12
skinparam sequenceMessageFontSize 11

title SD-02: Pencarian Fasilitas Umum (Grouping Toilet)

actor "Pengunjung\n(Browser)" as User #4A90D9
participant "Laravel\n(ChatbotController)" as Laravel #2E8B57
participant "ChatbotService\n(Laravel)" as Service #50C878
participant "Flask\n(app.py)" as Flask #E67E22
participant "ChatbotEngine\n(engine.py)" as Engine #8E44AD
participant "Search\n(search.py)" as Search #C0392B

== 1. User Tanya Lokasi Toilet ==
User -> Laravel : POST /chat\n{message: "dimana toilet?"}
activate Laravel
Laravel -> Service : predict("dimana toilet?")
activate Service
Service -> Flask : POST /predict\n{message: "dimana toilet?"}
activate Flask

== 2. Deteksi Tema & Grouping Gedung ==
Flask -> Engine : process("dimana toilet?")
activate Engine
Engine -> Search : collaborative_search("toilet")
activate Search
note right of Search
  Deteksi THEME "toilet"
  Kumpulkan semua ruangan toilet
  Temukan > 1 gedung
  → Return opsi per gedung
end note
Search --> Engine : [{id:"filter_toilet:Gedung A", name:"Gedung A"},\n{id:"filter_toilet:Gedung B", name:"Gedung B"}], score=0.96, is_option=true
deactivate Search
Engine --> Flask : (options, score=0.96, is_option=true)
deactivate Engine
Flask --> Service : {options: [Gedung A, Gedung B,...],\nresponse: "Silakan pilih lokasi terdekat Anda:"}
deactivate Flask
Service --> Laravel : {options: [...], intent: "cari_ruangan"}
deactivate Service
Laravel --> User : JSON {options, message}
deactivate Laravel

note over User
  Browser tampilkan tombol:
  [Gedung A] [Gedung B]
end note

== 3. User Pilih Gedung ==
User -> Laravel : POST /chat\n{message: "filter_toilet:Gedung A"}
activate Laravel
Laravel -> Service : predict("filter_toilet:Gedung A")
activate Service
Service -> Flask : POST /predict\n{message: "filter_toilet:Gedung A"}
activate Flask

== 4. Filter Toilet per Gedung ==
Flask -> Engine : process("filter_toilet:Gedung A")
activate Engine
Engine -> Search : collaborative_search("filter_toilet:Gedung A")
activate Search
note right of Search
  Deteksi prefix "filter_toilet:"
  Filter toilet di Gedung A saja
  → Return 1 toilet spesifik
end note
Search --> Engine : room_id=12, score=0.99, is_option=false
deactivate Search
Engine --> Flask : (room_id=12, score=0.99)
deactivate Engine
Flask --> Service : {best_room_id: 12, response: "Toilet Gedung A..."}
deactivate Flask

== 5. Tampilkan Info Toilet ==
Service --> Laravel : {rooms: [Toilet Gedung A], intent}
deactivate Service
Laravel --> User : JSON {message, rooms, intent}
deactivate Laravel

note over User
  Browser tampilkan:
  "Card Informasi Toilet di Gedung A"
  + Foto + Navigasi
end note

@enduml
